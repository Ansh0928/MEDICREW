# Neon PostgreSQL (production)
# Pooled connection — use for app queries
DATABASE_URL="postgres://[USER]:[PASSWORD]@[HOST].neon.tech/[DB]?sslmode=require"
# Direct connection — use for Prisma migrations (bypasses pooler)
DIRECT_URL="postgres://[USER]:[PASSWORD]@[HOST].neon.tech/[DB]?sslmode=require"

# LLM Providers
GROQ_API_KEY="your-groq-key"
OPENAI_API_KEY="your-openai-key"

# Inngest
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# Upstash Redis (rate limiting + clarification answer store)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key
CLERK_SECRET_KEY=sk_test_your_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/login
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/patient
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_APP_URL=http://localhost:3000
