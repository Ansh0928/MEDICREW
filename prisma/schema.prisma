// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Patient model - stores patient profile info
model Patient {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  age                Int?
  gender             String?
  knownConditions    String?
  deletedAt          DateTime?
  deletedEmail       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Phase 2: Extended profile fields
  dateOfBirth        DateTime?
  medications        String[]       @default([])
  allergies          String[]       @default([])
  emergencyContact   Json?          @db.JsonB
  gpDetails          Json?          @db.JsonB
  onboardingComplete Boolean        @default(false)
  supabaseUserId     String?        @unique

  consultations      Consultation[]
  notifications      Notification[]
  consents           PatientConsent[]
  symptomJournals    SymptomJournal[]
  careTeamStatus     CareTeamStatus?
}

// Consultation model - stores AI consultation history
model Consultation {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  symptoms      String
  urgencyLevel  String?  // emergency, urgent, routine, self_care
  redFlags      String?  // JSON array stored as string

  // AI responses stored as JSON strings
  triageResponse    String?
  gpResponse        String?
  specialistResponse String?
  recommendation    Json?    @db.JsonB

  createdAt     DateTime @default(now())
}

// Doctor model - for demo, simple doctor profiles
model Doctor {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  specialty     String
  createdAt     DateTime @default(now())

  notifications Notification[]
}

// Notification model - doctor to patient messages
model Notification {
  id          String   @id @default(cuid())

  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id])

  title       String
  message     String
  type        String   @default("info") // info, warning, appointment, prescription
  read        Boolean  @default(false)

  createdAt   DateTime @default(now())
}

// PatientConsent model - Privacy Act APP 11 consent records
model PatientConsent {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consentedAt    DateTime @default(now())
  consentVersion String   @default("1.0")
  dataCategories Json     @db.JsonB
  createdAt      DateTime @default(now())
}

// SymptomJournal model - Phase 2 patient symptom tracking
model SymptomJournal {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  severity  Int      // 1-5
  notes     String?
  createdAt DateTime @default(now())
}

// CareTeamStatus model - Phase 2 per-agent status messages for dashboard
model CareTeamStatus {
  id        String   @id @default(cuid())
  patientId String   @unique
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  statuses  Json     @db.JsonB
  updatedAt DateTime @updatedAt
}
