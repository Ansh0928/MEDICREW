// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Patient model - stores patient profile info
model Patient {
  id                 String         @id @default(cuid())
  name               String
  email              String         @unique
  age                Int?
  gender             String?
  knownConditions    String?
  deletedAt          DateTime?
  deletedEmail       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Phase 2: Extended profile fields
  dateOfBirth        DateTime?
  medications        String?      // Stored as JSON string
  allergies          String?      // Stored as JSON string
  emergencyContact   Json?
  gpDetails          Json?
  onboardingComplete Boolean        @default(false)
  supabaseUserId     String?        @unique
  clerkUserId        String?        @unique

  // Billing (Stripe)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionPlan      String    @default("free")   // "free" | "pro" | "partner"
  subscriptionStatus    String    @default("active")  // "active" | "past_due" | "canceled" | "paused" | "trialing"
  subscriptionPeriodEnd DateTime?

  checkInsOptOut     Boolean        @default(false)

  clinicId           String?
  clinic             Clinic?        @relation(fields: [clinicId], references: [id])

  consultations      Consultation[]
  notifications      Notification[]
  consents           PatientConsent[]
  symptomJournals    SymptomJournal[]
  careTeamStatus     CareTeamStatus?
  checkIns           CheckIn[]
}

// Consultation model - stores AI consultation history
model Consultation {
  id            String   @id @default(cuid())
  patientId     String
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  symptoms      String
  urgencyLevel  String?  // emergency, urgent, routine, self_care
  redFlags      String?  // JSON array stored as string

  // AI responses stored as JSON strings
  triageResponse    String?
  gpResponse        String?
  specialistResponse String?
  recommendation    Json?
  notes             Json?

  createdAt     DateTime @default(now())
  checkIns      CheckIn[]
}

// Clinic model - org/practice that groups doctors and patients
model Clinic {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  doctors   Doctor[]
  patients  Patient[]
}

// Doctor model - for demo, simple doctor profiles
model Doctor {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  specialty     String
  clerkUserId   String?  @unique
  createdAt     DateTime @default(now())

  clinicId      String?
  clinic        Clinic?  @relation(fields: [clinicId], references: [id])

  notifications Notification[]
}

// Notification model - doctor to patient messages
model Notification {
  id          String   @id @default(cuid())

  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)

  doctorId    String?
  doctor      Doctor?  @relation(fields: [doctorId], references: [id])

  title       String
  message     String
  type        String   @default("info") // info, warning, appointment, prescription
  read        Boolean  @default(false)

  createdAt   DateTime @default(now())
}

// PatientConsent model - Privacy Act APP 11 consent records
model PatientConsent {
  id             String   @id @default(cuid())
  patientId      String
  patient        Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consentedAt    DateTime @default(now())
  consentVersion String   @default("1.0")
  dataCategories Json
  createdAt      DateTime @default(now())
}

// SymptomJournal model - Phase 2 patient symptom tracking
model SymptomJournal {
  id        String   @id @default(cuid())
  patientId String
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  severity  Int      // 1-5
  notes     String?
  createdAt DateTime @default(now())
}

// CareTeamStatus model - Phase 2 per-agent status messages for dashboard
model CareTeamStatus {
  id        String   @id @default(cuid())
  patientId String   @unique
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  statuses  Json
  updatedAt DateTime @updatedAt
}

// ReferralToken model - signed token for unauthenticated GP referral letter access
model ReferralToken {
  id             String   @id @default(cuid())
  token          String   @unique @default(cuid())
  consultationId String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
}

// CheckIn model - Phase 3 proactive care loop check-ins
model CheckIn {
  id              String   @id @default(cuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  status          String   @default("pending")   // pending, responded, expired
  response        String?                          // "better" | "same" | "worse"
  responseText    String?
  notificationId  String?
  scheduledFor    DateTime
  respondedAt     DateTime?
  createdAt       DateTime @default(now())
}
